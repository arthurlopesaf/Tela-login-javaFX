<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="TelaCadastro" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.telalogin.TelaCadastroController">
    <children>
        <Label alignment="CENTER" layoutX="186.0" layoutY="22.0" prefHeight="28.0" prefWidth="229.0" text="Cadastro">
            <font>
                <Font name="Arial Bold" size="30.0" />
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="112.0" layoutY="153.0" prefHeight="30.0" prefWidth="104.0" text="Novo Usuário:">
            <font>
                <Font name="Arial Bold" size="14.0" />
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="221.0" layoutY="58.0" prefHeight="30.0" prefWidth="158.0" text="Crie seu usuário e senha">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="120.0" layoutY="200.0" prefHeight="30.0" prefWidth="104.0" text="Nova Senha:">
            <font>
                <Font name="Arial Bold" size="14.0" />
            </font>
        </Label>
        <TextField fx:id="txtNovoUsuario" layoutX="231.0" layoutY="155.0" />
        <TextField fx:id="txtNovaSenha" layoutX="231.0" layoutY="203.0" />
        <Button layoutX="266.0" layoutY="258.0" mnemonicParsing="false" onAction="#btnFecharTelaCadastro" prefHeight="25.0" prefWidth="79.0" text="Confirmar" />
        <Label layoutX="164.0" layoutY="114.0" text="Nome:">
            <font>
                <Font name="Arial Bold" size="14.0" />
            </font>
        </Label>
        <TextField fx:id="txtNovoNome" layoutX="231.0" layoutY="110.0" />
    </children>
</AnchorPane>
